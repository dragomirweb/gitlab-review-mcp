# NOTE: This file is auto-loaded by Bun when running `bun run start` or `bun run dev` directly.
# When the server is spawned as an MCP subprocess, pass env vars through your client config instead.
# See README.md for setup instructions.

# GitLab Authentication (use one of the following)
GITLAB_PAT=your_personal_access_token_here
GITLAB_OAUTH_TOKEN=your_oauth_token_here

# GitLab Base URL (defaults to https://gitlab.com)
GITLAB_BASE_URL=https://gitlab.com

# Default project ID (optional — avoids passing project_id on every tool call)
# Can be a numeric ID or URL-encoded path (e.g., "my-group/my-project")
GITLAB_PROJECT_ID=my-group/my-project
